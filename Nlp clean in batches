import pandas as pd
import pyarrow as pa
import pyarrow.parquet as pq
import re

def batch_preprocess(
    input_parquet,
    output_parquet,
    id_col,
    comment_col,
    batch_size=10_000
):
    print(f"Loading {input_parquet}...")
    df = pd.read_parquet(input_parquet, columns=[id_col, comment_col])
    total = len(df)
    print(f"Total rows: {total:,}")

    writer = None  # ParquetWriter will be opened on the first batch

    for start in range(0, total, batch_size):
        end = min(start + batch_size, total)
        print(f"Processing rows {start:,}–{end:,} ...", end=" ", flush=True)

        try:
            batch = df.iloc[start:end].copy()

            # ----------------------------------------------------------------
            # COMMENT CLEANING STARTS HERE
            # Replace everything below with your actual preprocessing steps
            # ----------------------------------------------------------------

            # Lowercase
            batch["cleaned_comment"] = batch[comment_col].str.lower()

            # Strip leading/trailing whitespace
            batch["cleaned_comment"] = batch["cleaned_comment"].str.strip()

            # Remove special characters, keep letters/numbers/spaces
            batch["cleaned_comment"] = batch["cleaned_comment"].apply(
                lambda x: re.sub(r"[^a-z0-9\s]", "", str(x)) if pd.notna(x) else x
            )

            # Collapse multiple spaces into one
            batch["cleaned_comment"] = batch["cleaned_comment"].apply(
                lambda x: re.sub(r"\s+", " ", str(x)) if pd.notna(x) else x
            )

            # Replace blanks/nulls that slipped through with NaN
            batch["cleaned_comment"] = batch["cleaned_comment"].replace("", pd.NA)

            # ----------------------------------------------------------------
            # COMMENT CLEANING ENDS HERE
            # ----------------------------------------------------------------

            # Keep only the ID and cleaned comment for output
            result = batch[[id_col, "cleaned_comment"]]

            # ----------------------------------------------------------------
            # APPEND TO PARQUET STARTS HERE
            # Each batch gets written to the output parquet file here.
            # The ParquetWriter keeps the file open and appends each batch
            # as a new row group — no temp files, no concat at the end.
            # ----------------------------------------------------------------

            table = pa.Table.from_pandas(result, preserve_index=False)

            if writer is None:
                # First batch — open the writer and define the file schema
                writer = pq.ParquetWriter(output_parquet, table.schema)

            writer.write_table(table)  # <-- this is where the batch gets appended

            # ----------------------------------------------------------------
            # APPEND TO PARQUET ENDS HERE
            # ----------------------------------------------------------------

            print(f"✓ {len(result):,} rows appended")

        except Exception as e:
            print(f"✗ FAILED — {e}")
            # Bad batch gets logged and skipped; rest of the run continues

    if writer:
        writer.close()  # Finalizes and closes the parquet file
        print(f"\nDone. Cleaned comments saved to: {output_parquet}")
    else:
        print("No data was written.")


# --- Run it ---
batch_preprocess(
    input_parquet="work_orders.parquet",
    output_parquet="work_orders_cleaned.parquet",
    id_col="WORK_ORDER_ID",
    comment_col="TECH_COMMENT",
    batch_size=10_000
)
