    ].sort_values("event_date")

    output_row = row.copy()

    for window in windows:

        start_date = ncm_date - pd.Timedelta(days=window)

        prior_window = meter_history[
            (meter_history["event_date"] >= start_date) &
            (meter_history["event_date"] < ncm_date)
        ]

        # normal event columns get summed
        for col in sum_cols:
            output_row[f"{col}_{window}d_prior"] = prior_window[col].sum()

        # estimate_flag gets MAX, not SUM
        output_row[f"estimate_flag_{window}d_prior"] = (
            prior_window["estimate_flag"].fillna(0).max()
        )

        # estimate max streak
        flags = prior_window["estimate_flag"].fillna(0).tolist()

        max_run = 0
        run = 0

        for v in flags:
            if v == 1:
                run += 1
                max_run = max(max_run, run)
            else:
                run = 0

        output_row[f"estimate_max_streak_{window}d_prior"] = max_run

    results.append(output_row)

