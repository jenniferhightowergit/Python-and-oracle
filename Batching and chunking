import duckdb
import gc

con = duckdb.connect("warehouse.duckdb")

meter_ids = (
    meter_sample["meter_id"]
    .dropna()
    .unique()
    .tolist()
)

batch_size = 500

for i in range(0, len(meter_ids), batch_size):

    batch = meter_ids[i:i+batch_size]

    meter_filter = ",".join(
        f"'{x}'" for x in batch
    )

    sql = f"""
    COPY (
        SELECT *
        FROM my_big_table
        WHERE meter_id IN ({meter_filter})
    )
    TO 'output/batch_{i}.parquet'
    (FORMAT PARQUET);
    """

    print(f"Running batch {i:,} to {i+len(batch):,}")

    con.execute(sql)

    del batch
    gc.collect()

con.close()
