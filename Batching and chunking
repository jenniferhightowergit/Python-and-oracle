import duckdb
from pathlib import Path
import math
import gc


def run_duckdb_meter_batches(
    duckdb_path,
    meter_id_query,
    batch_sql_template,
    output_folder,
    batch_size=100,
    meter_id_col="meter_id",
    memory_limit="4GB",
    temp_directory=None,
):
    output_folder = Path(output_folder)
    output_folder.mkdir(parents=True, exist_ok=True)

    con = duckdb.connect(duckdb_path)

    con.execute(f"SET memory_limit='{memory_limit}';")

    if temp_directory:
        Path(temp_directory).mkdir(parents=True, exist_ok=True)
        con.execute(f"SET temp_directory='{Path(temp_directory).as_posix()}';")

    meter_ids = [
        row[0]
        for row in con.execute(meter_id_query).fetchall()
        if row[0] is not None
    ]

    total_batches = math.ceil(len(meter_ids) / batch_size)

    for batch_num, start in enumerate(range(0, len(meter_ids), batch_size), start=1):
        batch_ids = meter_ids[start:start + batch_size]

        formatted_ids = ", ".join(f"'{str(x)}'" for x in batch_ids)
        meter_filter = f"{meter_id_col} IN ({formatted_ids})"

        batch_sql = batch_sql_template.format(meter_filter=meter_filter)

        output_file = output_folder / f"batch_{batch_num:05d}.parquet"

        print(f"Running batch {batch_num:,}/{total_batches:,}")

        con.execute(f"""
            COPY (
                {batch_sql}
            )
            TO '{output_file.as_posix()}'
            (FORMAT PARQUET);
        """)

        del batch_ids, formatted_ids, meter_filter, batch_sql, output_file
        gc.collect()

    con.close()
    gc.collect()


