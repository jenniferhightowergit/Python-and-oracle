def incremental_upsert(config):
    import duckdb

    con = duckdb.connect()

    target_path = config["target_path"]
    key_cols = config["key_cols"]

    # existing parquet
    con.execute(f"""
        CREATE OR REPLACE TABLE target AS
        SELECT * FROM read_parquet('{target_path}')
    """)

    # new/recent extract dataframe from Oracle
    source_df = get_oracle_data(config["source_query"])

    con.register("source_df", source_df)

    con.execute("""
        CREATE OR REPLACE TABLE source AS
        SELECT * FROM source_df
    """)

    join_condition = " AND ".join(
        [f"target.{col} = source.{col}" for col in key_cols]
    )

    con.execute(f"""
        MERGE INTO target
        USING source
        ON {join_condition}
        WHEN MATCHED THEN UPDATE SET *
        WHEN NOT MATCHED THEN INSERT *
    """)

    con.execute(f"""
        COPY target TO '{target_path}' (FORMAT PARQUET)
    """)



    incremental_upsert(TABLE_CONFIGS["work_orders"])
